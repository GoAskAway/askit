{
  "name": "ask",
  "version": 1,
  "hostToGuest": {
    "// --- 系统内置 ---": {},
    "HOST_VISIBILITY": {
      "summary": "Host 告知 Guest 当前 tab 是否可见，用于 cooperative sleep/resume（降 CPU）。",
      "payload": {
        "visible": "boolean",
        "tabId": "string?"
      }
    },
    "RECEIVER_BACKPRESSURE": {
      "summary": "Host/Receiver 发生背压（跳过部分 ops），提示 Guest 降载。",
      "payload": {
        "skipped": "number",
        "batchId": "number?",
        "applied": "number",
        "total": "number"
      }
    },
    "// --- 标准原生能力 ---": {},
    "SPEECH_RESPONSE": {
      "summary": "Host 返回语音操作执行结果",
      "payload": {
        "requestId": "string",
        "success": "boolean",
        "error": "unknown?"
      }
    },
    "HTTP_RESPONSE": {
      "summary": "Host 返回 HTTP 请求结果给 Guest",
      "payload": {
        "requestId": "string",
        "success": "boolean",
        "data": "unknown",
        "status": "number"
      }
    },
    "SEND_APP_INFO": {
      "summary": "Host 返回当前应用信息",
      "payload": {
        "requestId": "string",
        "appName": "string",
        "logo": "string",
        "languageContents": "unknown",
        "favoriteCount": "number",
        "usedCount": "number",
        "author": "string"
      }
    },
    "CLEAR_CHAT_HISTORY_RESULT": {
      "summary": "Host 返回清除对话记录结果",
      "payload": {
        "requestId": "string",
        "success": "boolean",
        "error": "unknown?"
      }
    },
    "CLOSE_EXTENSION_RESULT": {
      "summery": "Host 关闭拓展面板完成",
      "payload": {
        "requestId": "string",
        "success": "boolean",
        "error": "unknown?"
      }
    },
    "LANGUAGE_LIST": {
      "summary": "Host 返回语言列表",
      "payload": {
        "requestId": "string",
        "languages": "unknown",
        "current": "string"
      }
    },
    "SET_APP_LANGUAGE_RESULT": {
      "summary": "Host 返回设置语言结果",
      "payload": {
        "requestId": "string",
        "success": "boolean",
        "error": "unknown?"
      }
    },
    "SEND_EMAIL_RESULT": {
      "summary": "Host 返回发送邮件结果",
      "payload": {
        "requestId": "string",
        "success": "boolean",
        "error": "unknown?"
      }
    }
  },
  "guestToHost": {
    "// --- 系统内置 ---": {},
    "ASKIT_TOAST_SHOW": {
      "summary": "Internal: Guest requests host to show toast.",
      "payload": {
        "message": "string",
        "options": "unknown?"
      }
    },
    "ASKIT_HAPTIC_TRIGGER": {
      "summary": "Internal: Guest requests host to trigger haptic.",
      "payload": {
        "type": "string?"
      }
    },
    "GUEST_SLEEP_STATE": {
      "summary": "Guest 主动上报 sleep 状态（用于监控与督促）。",
      "payload": {
        "sleeping": "boolean",
        "tabId": "string?",
        "reason": "string?"
      }
    },
    "// --- 标准原生能力 ---": {},
    "SPEECH_REQUEST": {
      "summary": "Guest 请求语音合成或控制",
      "payload": {
        "requestId": "string",
        "text": "string?",
        "action": "'speak' | 'stop' | 'pause' | 'resume'"
      }
    },
    "HTTP_REQUEST": {
      "summary": "Guest 发起 HTTP 请求",
      "payload": {
        "requestId": "string",
        "url": "string",
        "method": "string?",
        "headers": "unknown?",
        "body": "unknown?"
      }
    },
    "GET_APP_INFO": {
      "summary": "Guest 请求当前 应用信息",
      "payload": {
        "requestId": "string"
      }
    },
    "GET_LANGUAGE_LIST": {
      "summary": "Guest 请求获取语言列表",
      "payload": {
        "requestId": "string"
      }
    },
    "SET_APP_LANGUAGE": {
      "summary": "Guest 请求设置当前引用语言",
      "payload": {
        "requestId": "string",
        "language": "string"
      }
    },
    "CLEAR_CHAT_HISTORY": {
      "summary": "Guest 请求清除对话记录",
      "payload": {
        "requestId": "string"
      }
    },
    "CLOSE_EXTENSION": {
      "summary": "Guest 请求关闭扩展",
      "payload": {
        "requestId": "string"
      }
    },
    "SEND_EMAIL": {
      "summary": "Guest 请求发送邮件",
      "payload": {
        "requestId": "string",
        "to": "string",
        "subject": "string"
      }
    }
  }
}
